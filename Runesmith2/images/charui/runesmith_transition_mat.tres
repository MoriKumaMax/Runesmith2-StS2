[gd_resource type="ShaderMaterial" load_steps=3 format=3 uid="uid://bd6qy5x3m2u21"]

[ext_resource type="Texture2D" uid="uid://ds6uevnlwsopk" path="res://Runesmith2/images/charui/runesmith_transition.png" id="1_utalf"]

[sub_resource type="Shader" id="Shader_a0egw"]
code = "shader_type canvas_item;

uniform sampler2D transitionTex;
uniform float threshold : hint_range(0,1);

void fragment() {
    float falloff = 1.0 - texture(transitionTex, UV).r;
    
    // helps with falloff artifacts issues towards the transition extremes
    float remap  = mix(-0.1, 1.1, threshold);
    falloff = step(falloff, remap);
    COLOR.a = falloff;
}
"

[resource]
shader = SubResource("Shader_a0egw")
shader_parameter/transitionTex = ExtResource("1_utalf")
shader_parameter/threshold = 0.33200001577
